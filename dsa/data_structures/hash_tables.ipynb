   "source": [
    "#Create a Hash Function that sums the Unicode numbers of each character and return a number between 0 and 9:\n",
    "\n",
    "def hash_function(value):\n",
    "    sum =0\n",
    "    for char in value:\n",
    "        sum+= ord(char)\n",
    "\n",
    "    modulo = sum %10\n",
    "    return modulo\n"
   ]
  },
