   "source": [
    "#Create an algorithm to find the lowest value in a list\n",
    "\n",
    "a =[5,2,1,7,9]\n",
    "\n",
    "min_val = a[0]\n",
    "\n",
    "for i in a:\n",
    "    if i < min_val:\n",
    "        min_val=i\n",
    "\n",
    "print(min_val)\n"
   ]
